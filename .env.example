# ─────────────────────────────────────────────────────────────────────────────
# AutoTrade — Environment Variable Template
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Alpaca API credentials ────────────────────────────────────────────────────
# Get your paper trading keys from: https://app.alpaca.markets/paper-trading
ALPACA_API_KEY=your_paper_api_key_here
ALPACA_SECRET_KEY=your_paper_secret_key_here

# Set to true for paper trading (recommended during development)
PAPER_TRADING=true

# Data feed: "iex" (free, ~15 min delay) or "sip" (paid, real-time)
ALPACA_DATA_FEED=iex

# ── App configuration ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# Directory for the local parquet data cache (relative to project root)
CACHE_DIR=cache

# How long cached market data is considered fresh (seconds)
CACHE_TTL_SECONDS=3600

# ── Portfolio ─────────────────────────────────────────────────────────────────
# Starting capital for paper trading and backtests (USD)
INITIAL_CAPITAL=100000.0

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_TITLE=AutoTrade — Algorithmic Trading System
DEFAULT_SYMBOLS=["AAPL","MSFT","NVDA","GOOGL","AMZN"]
DEFAULT_LOOKBACK_DAYS=365

# ── LLM (future — for signal generator) ──────────────────────────────────────
# OPENAI_API_KEY=your_openai_key_here
